##############################################
# Dockerfile.app.s390x
#
# Application image built on top of the spyre-toolchain image. That toolchain is
# produced by EITHER Dockerfile-torch-spyre.s390x (current: on the 2.0
# spyre-runtime-dev base, VF-compute flex) or the older Dockerfile.base.s390x
# (granite-eval). Layers vllm + opencv + hf-xet + numactl + spyre-inference on
# top, in a multi-stage build mirroring aiu-inference-dev/Dockerfile.s390x.
# Installs into the toolchain image's uv venv at ${DTI_PROJECT_ROOT}/.venv, which
# has torch 2.11 + torch_spyre and — via --system-site-packages — inherits
# torch_sendnn / torchvision / PIL from the base image's system site-packages.
# This Dockerfile is written in terms of inherited env (${DTI_PROJECT_ROOT},
# ${SENTIENT_BASE_INSTALL_DIR}, …), so it works unchanged on either toolchain.
#
# Stages:
#   builder-base                — inherits envs from toolchain (VIRTUAL_ENV=
#                                 ${DTI_PROJECT_ROOT}/.venv, .venv/bin on PATH)
#   numa-build                  — numactl 2.0.18 -> /opt/numactl
#   rust                        — rustup stable for hf-xet build
#   hf-xet-builder              — hf-xet 1.4.3 wheel
#   opencv-builder              — opencv-python-headless==4.12.0.88 wheel
#   vllm-builder                — vllm v0.20.1 wheel + install
#   spyre-inference-builder     — spyre-inference wheel + install
#   runtime-base                — clean FROM target for release
#   release                     — final image, USER 1234:0, EXPOSE 8000
#   dev                         — adds nano/sudo + test deps
#
# Build (after building Dockerfile.base.s390x as icr.io/ocp-ai-on-z/aiu-dev/spyre-toolchain:s390x):
#   podman build \
#       --build-arg BASE_IMAGE=icr.io/ocp-ai-on-z/aiu-dev/spyre-toolchain:s390x \
#       --build-arg VLLM_VERSION=v0.20.1 \
#       -f Dockerfile.app.s390x \
#       --target release \
#       -t localhost/spyre-inference:s390x \
#       /Users/ritikdhiranan/PycharmProjects/spyre-inference
#
# Run (single-card debug on a multi-AIU host):
#   grp=$(readlink /sys/bus/pci/devices/0009:00:00.0/iommu_group | xargs basename)
#   podman run --rm -it \
#       --device /dev/vfio/vfio --device /dev/vfio/$grp \
#       --cap-add=IPC_LOCK --ulimit memlock=-1:-1 --shm-size=8g \
#       -e SPYRE_SINGLE_CARD_BDF=0009:00:00.0 \
#       -e FLEX_DEVICE=PF \
#       -e VLLM_MODEL_PATH=/path/to/model \
#       --entrypoint /bin/bash localhost/spyre-inference:s390x -l
#
# NB: VF (Virtual Function) execution is supported via the runtime's stream
# support (torch-spyre/flex main). FLEX_DEVICE defaults to PF below; set
# FLEX_DEVICE=VF to run on a VF.
##############################################

ARG BASE_IMAGE="icr.io/ocp-ai-on-z/aiu-dev/spyre-toolchain:s390x"
ARG VLLM_VERSION="v0.20.1"
ARG SPYRE_INFERENCE_REF="main"
ARG PYTHON_VERSION="3.12"

##############################################
# builder-base — inherits everything from the toolchain image: the active venv
# (VIRTUAL_ENV=${DTI_PROJECT_ROOT}/.venv, .venv/bin on PATH), the sentient
# install dirs, LD_LIBRARY_PATH, and the rust/openssl build envs. uv pip
# install (no --system) therefore targets the venv.
##############################################
FROM ${BASE_IMAGE} AS builder-base

ARG PYTHON_VERSION
ENV PYTHON_VERSION=${PYTHON_VERSION}

USER root
# Non-login shell: avoids the base image's broken /etc/profile.d cp + podman
# boot-id noise. The venv is already active via inherited VIRTUAL_ENV/PATH.
SHELL ["/usr/bin/bash", "-c"]

# Prepend the venv's torch libs so the vllm CPU build links against torch 2.11.
ENV LD_LIBRARY_PATH=${DTI_PROJECT_ROOT}/.venv/lib64/python${PYTHON_VERSION}/site-packages/torch/lib:${LD_LIBRARY_PATH}

# vllm's requirements/build/cpu.txt adds `--extra-index-url <pytorch-cpu>` and
# pins setuptools==77.0.3. uv prioritizes extra indexes with a first-index
# strategy: it finds setuptools on the pytorch-cpu index (wrong version) and
# won't fall back to PyPI for 77.0.3. unsafe-best-match makes uv consider all
# versions across all (trusted) indexes — setuptools/cmake from PyPI, +cpu
# wheels from pytorch-cpu. (torch is overridden to never-install anyway.)
ENV UV_INDEX_STRATEGY=unsafe-best-match

##############################################
# numa-build — produces /opt/numactl
# vllm._C.so dlopens libnuma.so.1 at import time; the base image ships
# numactl-libs already, but a self-built numactl gives us static libnuma.a
# for the vllm wheel link step.
##############################################
FROM builder-base AS numa-build

WORKDIR /tmp
RUN curl -LO https://github.com/numactl/numactl/archive/refs/tags/v2.0.18.tar.gz && \
    tar -xvzf v2.0.18.tar.gz && \
    cd numactl-2.0.18 && \
    ./autogen.sh && \
    ./configure --prefix=/opt/numactl && \
    make -j"$(nproc)" && \
    make install

##############################################
# rust — rustup stable, mounted into hf-xet-builder + spyre-inference build.
##############################################
FROM builder-base AS rust

ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH="$CARGO_HOME/bin:$RUSTUP_HOME/bin:$PATH"

RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --default-toolchain stable && \
    . "$CARGO_HOME/env" && \
    rustup default stable && \
    rustup show

##############################################
# hf-xet-builder — HuggingFace xet wheel (no s390x prebuilt on PyPI).
##############################################
FROM builder-base AS hf-xet-builder

ARG HF_XET_VERSION=1.4.3

WORKDIR /tmp
ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH="$CARGO_HOME/bin:$RUSTUP_HOME/bin:$PATH"

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,from=rust,source=/root/.cargo,target=/root/.cargo,rw \
    --mount=type=bind,from=rust,source=/root/.rustup,target=/root/.rustup,rw \
    uv pip install --no-cache maturin patchelf && \
    git clone --branch v${HF_XET_VERSION} --depth 1 https://github.com/huggingface/xet-core.git && \
    cd xet-core/hf_xet/ && \
    python3 -m maturin build --release --out dist && \
    mkdir -p /tmp/hf-xet/dist && \
    cp dist/*.whl /tmp/hf-xet/dist/

##############################################
# opencv-builder — opencv-python-headless==4.12.0.88 from source.
# 4.13.0.90 has a libxcb packaging bug that breaks headless installs;
# pyproject.toml override-dependencies pins 4.12.0.88 explicitly.
##############################################
FROM builder-base AS opencv-builder

WORKDIR /tmp
ARG OPENCV_VERSION=88

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --no-cache numpy setuptools wheel scikit_build build && \
    git clone --recursive https://github.com/opencv/opencv-python.git -b ${OPENCV_VERSION} && \
    cd opencv-python && \
    python3 -m build --wheel --installer=uv --outdir /tmp/opencv-python/dist

##############################################
# vllm-builder — pin VLLM_VERSION, build CPU wheel against torch 2.11.
##############################################
FROM builder-base AS vllm-builder

ARG VLLM_VERSION
ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH="$CARGO_HOME/bin:$RUSTUP_HOME/bin:$PATH"
ENV CXXFLAGS="-Wno-bool-compare"
# Cargo: use the sparse HTTP registry index instead of the legacy git index.
# vllm pulls outlines-core (no s390x wheel -> built from Rust source via
# maturin); the git-index cache from the rust stage goes stale and triggers
# "failed to verify the checksum of <crate>". Sparse fetches the index fresh
# over HTTP and sidesteps that. Retry/CLI git for flaky network.
ENV CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse \
    CARGO_NET_GIT_FETCH_WITH_CLI=true \
    CARGO_NET_RETRY=5
# vllm's CPU extension (csrc/cpu/utils.cpp) #includes <numa.h>. The base image
# only ships numactl-libs (runtime libnuma.so.1), not the dev header. Bring in
# the numactl we built in numa-build (/opt/numactl has include/numa.h + lib)
# and put /usr/local/include on the compiler's search path.
ENV C_INCLUDE_PATH="/usr/local/include:${C_INCLUDE_PATH:-}"

WORKDIR /usr/src

# numactl headers + libs for the vllm CPU compile (numa.h). No ldconfig needed
# at build time — the compile finds numa.h via C_INCLUDE_PATH and links libnuma
# via /usr/local/lib (also on LD_LIBRARY_PATH).
COPY --from=numa-build /opt/numactl/. /usr/local/

# overrides.txt: packages we either pre-provide (torch, torchvision,
# torch-sendnn, torch-spyre from the toolchain image; pyarrow, opencv,
# hf-xet from builder stages) or skip entirely (numba/llvmlite have no
# libLLVM-15.so on s390x; RH's vllm fork drops them too).
RUN cat <<'EOF' > /usr/src/overrides.txt
torch; sys_platform == 'never'
torchaudio; sys_platform == 'never'
torchvision; sys_platform == 'never'
torch-sendnn; sys_platform == 'never'
pyarrow; sys_platform == 'never'
opentelemetry-sdk; sys_platform == 'never'
opentelemetry-api; sys_platform == 'never'
opentelemetry-exporter-otlp; sys_platform == 'never'
opentelemetry-semantic-conventions-ai; sys_platform == 'never'
opencv-python-headless; sys_platform == 'never'
torch-spyre; sys_platform == 'never'
torch_spyre; sys_platform == 'never'
numba; sys_platform == 'never'
llvmlite; sys_platform == 'never'
llguidance>=1.7.3
compressed-tensors==0.14.0.1
EOF

# Install the wheels we built in parallel stages into system Python.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,from=rust,source=/root/.cargo,target=/root/.cargo,rw \
    --mount=type=bind,from=rust,source=/root/.rustup,target=/root/.rustup,rw \
    --mount=type=bind,from=hf-xet-builder,source=/tmp/hf-xet/dist,target=/tmp/hf-xet-wheels/ \
    --mount=type=bind,from=opencv-builder,source=/tmp/opencv-python/dist,target=/tmp/opencv-wheels/ \
    uv pip install --no-cache \
        $(ls /tmp/hf-xet-wheels/*.whl) \
        $(ls /tmp/opencv-wheels/*.whl)

# vllm wheel build. CMAKE_PREFIX_PATH steers cmake at the nanobind installed
# by the toolchain image (uv pip install nanobind==2.9.2).
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,from=rust,source=/root/.cargo,target=/root/.cargo,rw \
    --mount=type=bind,from=rust,source=/root/.rustup,target=/root/.rustup,rw \
    git clone https://github.com/vllm-project/vllm.git /usr/src/vllm && \
    cd /usr/src/vllm && \
    git checkout tags/${VLLM_VERSION} && \
    uv pip install --no-cache \
        --overrides /usr/src/overrides.txt \
        pip \
        -r requirements/build/cpu.txt && \
    export CMAKE_PREFIX_PATH=$(python3 -m nanobind --cmake_dir):${CMAKE_PREFIX_PATH:-} && \
    mkdir -p /tmp/vllm-wheels && \
    VLLM_TARGET_DEVICE=cpu VLLM_CPU_MOE_PREPACK=0 \
        pip wheel --no-build-isolation --no-deps -w /tmp/vllm-wheels/ . && \
    uv pip install --no-cache \
        --overrides /usr/src/overrides.txt \
        /tmp/vllm-wheels/vllm-*.whl

##############################################
# spyre-inference-builder — install spyre-inference into the same system
# Python as vllm. Lock-pins filter strips packages we already provided.
##############################################
FROM vllm-builder AS spyre-inference-builder

ARG SPYRE_INFERENCE_REF
ENV CARGO_HOME=/root/.cargo
ENV RUSTUP_HOME=/root/.rustup
ENV PATH="$CARGO_HOME/bin:$RUSTUP_HOME/bin:$PATH"

# Use the local working tree so the Dockerfile pairs with the checked-out
# source. (Alternative: git clone the public repo at SPYRE_INFERENCE_REF.)
COPY . /usr/src/spyre-inference

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,from=rust,source=/root/.cargo,target=/root/.cargo,rw \
    --mount=type=bind,from=rust,source=/root/.rustup,target=/root/.rustup,rw \
    cd /usr/src/spyre-inference && \
    uv export --frozen --no-dev --no-hashes --no-emit-project \
        --format requirements-txt -o /usr/src/lock-pins.txt && \
    grep -vE '^(torch|torchvision|torch-sendnn|hf-xet|opencv-python-headless|torch-spyre|torch_spyre|vllm|pyarrow|llvmlite|numba)([= ]|$)' \
        /usr/src/lock-pins.txt > /usr/src/lock-constraints.txt && \
    mkdir -p /tmp/spyre-wheels && \
    pip wheel --no-build-isolation --no-deps -w /tmp/spyre-wheels/ . && \
    uv pip install --no-cache \
        --overrides /usr/src/overrides.txt \
        --constraint /usr/src/lock-constraints.txt \
        /tmp/spyre-wheels/spyre_inference-*.whl

# Force pure-Python protobuf. The C++ extension crashes on big-endian
# s390x; pairs with PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python in release.
RUN find ${DTI_PROJECT_ROOT}/.venv -name '_message*.so'          -path '*/google/protobuf/*' -delete && \
    find ${DTI_PROJECT_ROOT}/.venv -name '_api_implementation*.so' -path '*/google/protobuf/*' -delete

# Smoke test the assembled environment.
RUN python3 -c "import torch, torch_spyre, torch_sendnn, vllm, spyre_inference; \
                print('app ok:', torch.__version__, spyre_inference.__name__)"

##############################################
# runtime-base — clean FROM target for release. Toolchain image already has
# all the runtime libs; this stage exists so release doesn't carry builder
# cruft. No extra DNF installs needed.
##############################################
FROM ${BASE_IMAGE} AS runtime-base

USER root
ARG PYTHON_VERSION
ENV PYTHON_VERSION=${PYTHON_VERSION}

##############################################
# release — final image for serving. Copies the assembled uv venv (now with
# vllm + opencv + hf-xet + spyre-inference added) from spyre-inference-builder
# over the toolchain's; the base's system site-packages (torch_sendnn /
# torchvision / PIL) are inherited via runtime-base (FROM the toolchain) and seen
# through the venv's --system-site-packages. Drops numactl, sets LD_LIBRARY_PATH,
# ENV, profile.d defenses, ENTRYPOINT.
##############################################
FROM runtime-base AS release

ARG PYTHON_VERSION

# Overlay the venv from the builder (now with vllm + opencv + hf-xet +
# spyre-inference added) over the toolchain image's venv. runtime-base is
# FROM the toolchain image, so the sentient/ install dirs, /usr/local base
# packages, and AIU RPM libs are already present — only the venv changed.
# This is the venv equivalent of `COPY --from=… /opt/vllm /opt/vllm`.
COPY --from=spyre-inference-builder ${DTI_PROJECT_ROOT}/.venv ${DTI_PROJECT_ROOT}/.venv

# numactl static + dynamic libs. ldconfig lives in /usr/sbin (not on the
# venv-first PATH); full path + fallback so the runtime loader cache picks up
# libnuma.so.1 (LD_LIBRARY_PATH also covers /usr/local/lib).
COPY --from=numa-build /opt/numactl/. /usr/local/
RUN /usr/sbin/ldconfig 2>/dev/null || /sbin/ldconfig 2>/dev/null || true

# Capture the toolchain's overlay install dir under a dedicated name BEFORE we
# repoint SENTIENT_BASE_INSTALL_DIR. The base image inherited
# SENTIENT_BASE_INSTALL_DIR=${DTI_PROJECT_ROOT}/sentient (where the build
# installed our rebuilt deeptools/flex/libaiupti/spyre_comms). But the base's
# /etc/profile.d/ibm-aiu-setup.sh reuses SENTIENT_BASE_INSTALL_DIR at runtime to
# locate its AIU discovery scripts (aiu-discover-topo, aiu-assign-ranks.py) and
# senlib — all of which live at /opt/ibm/spyre. If it points at our overlay dir,
# discovery bails ("Missing .../aiu-assign-ranks.py"), the autogen senlib config
# is never produced, and the container can't open the AIU. So: keep the overlay
# path in SPYRE_OVERLAY_DIR, and repoint SENTIENT_BASE_INSTALL_DIR=/opt/ibm/spyre.
ENV SPYRE_OVERLAY_DIR=${SENTIENT_BASE_INSTALL_DIR}

# LD_LIBRARY_PATH ordering — our rebuilt flex/deeptools/libaiupti/spyre_comms
# (SPYRE_OVERLAY_DIR) BEFORE the base image's /opt/ibm/spyre/*/lib RPM versions,
# then the venv's torch libs. Non-login processes (ENTRYPOINT) inherit this;
# login shells go through /etc/profile.d/ (zz-flex-overlay.sh below re-prepends
# the overlay after ibm-aiu-setup.sh demotes it).
ENV LD_LIBRARY_PATH="${SPYRE_OVERLAY_DIR}/runtime/lib:${SPYRE_OVERLAY_DIR}/deeptools/lib:${SPYRE_OVERLAY_DIR}/libaiupti/lib:${SPYRE_OVERLAY_DIR}/spyre_comms/lib:${DTI_PROJECT_ROOT}/.venv/lib64/python${PYTHON_VERSION}/site-packages/torch/lib:/opt/ibm/spyre/senlib/lib:/opt/ibm/spyre/deeptools/lib:/opt/ibm/spyre/spyre-comms/lib:/usr/local/lib"

# Repoint SENTIENT_BASE_INSTALL_DIR at the base RPM tree so ibm-aiu-setup.sh
# finds aiu-discover-topo / aiu-assign-ranks.py / senlib at runtime.
ENV SENTIENT_BASE_INSTALL_DIR=/opt/ibm/spyre

# Reconcile the flex runtime to a SINGLE const-ABI copy. The toolchain image
# already ran this (Dockerfile.base.s390x step 10b), so on a clean base this is
# a fast no-op guard; we re-run it here so the app image is correct even when
# built on a base that predates the reconcile. It physically deletes the stale
# /opt/ibm/spyre/runtime/lib/libflex.so (NON-const setPipelineBarrier) that the
# base image ships, leaving the overlay's const-ABI libflex as the only copy on
# the system. With one libflex, no LD_LIBRARY_PATH ordering can reintroduce the
# `undefined symbol: _ZNK…setPipelineBarrierEb` import failure. Fails the build
# if more than one libflex remains or it lacks the const symbol. Keys off
# SPYRE_OVERLAY_DIR (set above). senlib / discovery scripts are left untouched.
COPY ./container-scripts/reconcile-flex-runtime.sh /usr/local/bin/reconcile-flex-runtime.sh
RUN chmod +x /usr/local/bin/reconcile-flex-runtime.sh && \
    /usr/local/bin/reconcile-flex-runtime.sh

# Defense-in-depth profile.d scripts. The base image's
# /etc/profile.d/ibm-aiu-setup.sh runs on login shells and re-prepends
# /opt/ibm/spyre/*/lib to LD_LIBRARY_PATH (demoting our overlay). The
# zz- prefix sorts alphabetically AFTER ibm-aiu-setup.sh so these win.
# NB: flex shadowing is already structurally impossible after the reconcile
# above (only one libflex exists); zz-flex-overlay.sh still matters for PATH
# (dxp_standalone kernel bundler) and the non-flex overlay libs.
COPY ./container-scripts/zz-flex-overlay.sh    /etc/profile.d/zz-flex-overlay.sh
COPY ./container-scripts/zz-aiu-single-card.sh /etc/profile.d/zz-aiu-single-card.sh
RUN chmod 0644 /etc/profile.d/zz-flex-overlay.sh /etc/profile.d/zz-aiu-single-card.sh

# Environment for spyre-inference + vllm runtime.
# FLEX_DEVICE=PF — default; VF is also supported (run with -e FLEX_DEVICE=VF),
# backed by the runtime stream support in torch-spyre/flex main.
# VLLM_ATTENTION_BACKEND=CUSTOM — force the plugin's Spyre attention backend.
# Without this, vLLM auto-selects its default CPU backend (TORCH_SDPA), which
# produces GARBAGE output in float16 (it is only numerically stable in
# bfloat16). The plugin's CUSTOM Spyre attention is correct in float16; this
# env makes the server (and the offline example) use it by default.
ENV DTLOG_COLOR=0 \
    DTLOG_LEVEL=error \
    DT_DEEPRT_VERBOSE="-1" \
    MASTER_ADDR=localhost \
    MASTER_PORT=12355 \
    TOKENIZERS_PARALLELISM=false \
    TORCH_SENDNN_LOG=CRITICAL \
    VLLM_PLUGINS=spyre_inference \
    VLLM_ATTENTION_BACKEND=CUSTOM \
    FLEX_DEVICE=PF \
    FLEX_COMPUTE=SENTIENT \
    PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# Helper scripts to reconfigure aius at runtime and set aiu env vars.
COPY ./container-scripts /home/senuser/container-scripts
RUN chmod +x /home/senuser/container-scripts/*.sh || true

# Create the senuser account (UID 1234, GID 0). The base image ships no senuser,
# so pwd.getpwuid(1234) KeyErrors — torch's default_cache_dir() (via
# getpass.getuser()) and other libs look up the username at runtime and crash.
# Also create writable /home/senuser and /etc/aiu: ibm-aiu-setup.sh copies the
# autogen senlib config to /etc/aiu/senlib_config.json and ${HOME}/.senlib.json,
# and as the non-root senuser (gid 0) needs both writable. No pre-existing
# root-owned senlib_config.json may remain or the overwrite is denied.
RUN (getent passwd senuser >/dev/null || \
        useradd -u 1234 -g 0 -m -d /home/senuser -s /bin/bash senuser) 2>/dev/null || true; \
    grep -q '^senuser:' /etc/passwd || \
        echo 'senuser:x:1234:0:senuser:/home/senuser:/bin/bash' >> /etc/passwd; \
    rm -f /etc/aiu/senlib_config.json; \
    mkdir -p /home/senuser/.cache /etc/aiu && \
    chown -R 1234:0 /home/senuser /etc/aiu && \
    chmod -R g+rwX /home/senuser /etc/aiu

# Remove AIU discovery caches baked into the base image. If the base was
# snapshotted on a multi-AIU host, /tmp/etc/ibm/spyre/topo.json (and possibly
# /etc/ibm/spyre/topo.json) can list cards not mapped into this container.
# ibm-aiu-setup.sh then trusts that cache ("Using cache") instead of discovering
# this container's devices, and senlib tries to open every listed card — failing
# on /dev/vfio/<n> not passed via --device (RAS 0x332b DeviceOpenFail). With the
# caches gone, discovery runs fresh at startup and only sees the AIUs actually
# mapped in. This also drops the root-owned /tmp/etc whose chmod the non-root
# entrypoint can't change — important since the toolchain builds as root and the
# spyre-runtime-dev base also pre-creates /tmp/etc.
RUN rm -rf /tmp/etc \
           /etc/ibm/spyre/topo.json \
           /etc/ibm/spyre/senlib_config.json 2>/dev/null || true

# PATH: overlay bin dirs FIRST (the rebuilt dxp_standalone kernel-bundler must
# match the overlay libs on LD_LIBRARY_PATH — mixing the base /opt/ibm/spyre
# dxp_standalone binary with our overlay libs aborts with std::out_of_range
# (map::at) during AIU graph compilation), then the venv bin so `python3`/`vllm`
# resolve to the venv interpreter (torch 2.11, torch_spyre, vllm, spyre_inference).
# USER/LOGNAME: torch's default_cache_dir() calls getpass.getuser(); these are
# belt-and-braces alongside the senuser passwd entry created above so the
# username always resolves.
ENV HOME=/home/senuser \
    USER=senuser \
    LOGNAME=senuser \
    PATH=/home/senuser/.local/bin:${SPYRE_OVERLAY_DIR}/runtime/bin:${SPYRE_OVERLAY_DIR}/deeptools/bin:${SPYRE_OVERLAY_DIR}/libaiupti/bin:${SPYRE_OVERLAY_DIR}/spyre_comms/bin:${DTI_PROJECT_ROOT}/.venv/bin:/usr/local/bin:/usr/bin:/bin

WORKDIR ${HOME}

# senuser's UID is 1234 (base image convention)
USER 1234:0

# Default vLLM OpenAI server endpoint
EXPOSE 8000

# Start vllm in server mode. User must provide VLLM_MODEL_PATH (or pass the
# model as a positional arg) and VLLM_AIU_PCIE_IDS if running with a subset
# of AIUs. For single-card debug, also set SPYRE_SINGLE_CARD_BDF.
ENTRYPOINT ["/home/senuser/container-scripts/vllm_start_s390x.sh"]

##############################################
# dev — release + nano/sudo + the spyre-inference dev-group test deps.
##############################################
FROM release AS dev

USER root

RUN dnf install -y nano sudo vim && \
    dnf clean all

# Lean test deps for the Spyre device/layer tests. The dev group's
# spyre-testing-plugin (tests/plugin) hard-pins the full upstream vLLM test
# stack (bitsandbytes, librosa/numba/llvmlite, av, mteb, gpt-oss, …), almost
# none of which has an s390x wheel — they back upstream multimodal suites we
# don't run here. So instead of compiling the whole dev group, install just
# pytest + pyyaml and the plugin itself with --no-deps (which still registers
# its pytest11 entrypoint + fixtures). The Spyre layer tests (test_rms_norm,
# test_mlp, test_silu_and_mul, test_parallel_lm_head, test_spyre_attn) need
# nothing more.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,from=spyre-inference-builder,source=/usr/src/spyre-inference,target=/usr/src/spyre-inference,rw \
    cd /usr/src/spyre-inference && \
    uv pip install --no-cache pytest pyyaml && \
    uv pip install --no-cache --no-deps /usr/src/spyre-inference/tests/plugin

USER 1234:0
WORKDIR ${HOME}

ENTRYPOINT ["/home/senuser/container-scripts/vllm_start_s390x.sh"]