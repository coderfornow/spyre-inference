##############################################
# Dockerfile-torch-spyre.s390x
#
# Toolchain image built on the spyre-runtime-dev base, which already ships the
# VF-capable AIU stack + the full Python runtime — we only add torch-spyre.
#
# Base: icr.io/zai_spyre/s390x/spyre-runtime-dev:main provides, validated:
#   - /opt/ibm/spyre native stack with the VF-Compute flex:
#       ibm-flex 2.0.0-…+269.8c0adfc  (commit 8c0adfc = flex main HEAD; includes
#         "Implement VF Compute" #1007 AND "add MemoryType to FlexAllocator" #1008
#         — flex now DECLARES flex::MemoryType, which torch-spyre main requires),
#       ibm-deeptools +716.5012ccd, ibm-senlib +140.a82acf3, ibm-spyre-comms.
#   - System Python 3.12 with torch 2.11.0+cpu, torch_sendnn, torchvision, PIL.
#   - uv 0.11.x on PATH.
# The ONLY thing missing is torch_spyre — so this image builds just that.
#
# Why we no longer rebuild flex/deeptools (vs the earlier plan): the older
# spyre-backend:latest-198 base baked a ~May-19 flex (fe67319) that predates
# VF Compute (#1007, May 30) and MemoryType (#1008), so torch-spyre main failed
# to compile (`error: 'flex::MemoryType' has not been declared`). This base
# carries the May-30 flex RPM, so the prebuilt flex is correct and reused as-is.
#
# torch_sendnn is NOT a uv-resolved dependency of torch-spyre
# (pyproject.toml: `# "torch_sendnn"  # must be installed manually`); it only
# needs to be importable at runtime, which the --system-site-packages venv
# inherits from the base's /usr/local. So we do NOT build torch_sendnn.
#
# Image contract (MUST match Dockerfile.base.s390x so Dockerfile.app.s390x
# builds on top unchanged):
#   - VIRTUAL_ENV=${DTI_PROJECT_ROOT}/.venv (python3.12, lib64 scheme),
#     --system-site-packages, holding torch 2.11 + torch_spyre and inheriting
#     torch_sendnn/torchvision/PIL from the base; .venv/bin on PATH.
#   - SENTIENT_BASE_INSTALL_DIR=${DTI_PROJECT_ROOT}/sentient with
#     runtime/ deeptools/ libaiupti/ spyre_comms/ — here a SYMLINK FARM onto
#     /opt/ibm/spyre/*, so SPYRE_OVERLAY_DIR (captured by the app image) and the
#     base RPM tree resolve to the SAME single libflex (reconcile is a no-op).
#   - PYTHON_VERSION=3.12, LANG/LC_ALL, UV_* and the rust/openssl build envs.
#
# Build:
#   eval "$(ssh-agent -s)" && ssh-add ~/.ssh/id_rsa   # key with github.com access
#   ssh-add -l                                        # confirm 1+ identity BEFORE building
#   cd /Users/ritikdhiranan/PycharmProjects
#   podman build --format docker \
#       --security-opt seccomp=unconfined --security-opt label=disable \
#       --ssh default=$SSH_AUTH_SOCK \
#       -f spyre-inference/Dockerfile-torch-spyre.s390x \
#       -t localhost/spyre-toolchain:s390x \
#       .
#
#   --format docker : honor the SHELL directive below (OCI ignores it).
#   --security-opt seccomp=unconfined --security-opt label=disable :
#       s390x build hosts otherwise block glibc's RELRO mprotect.
#
# Build context note: must be the parent of both spyre-inference/ and
# torch-spyre-docs/ so the COPY ./torch-spyre-docs line resolves.
##############################################

ARG BASE_IMAGE="icr.io/zai_spyre/s390x/spyre-runtime-dev:main"

FROM ${BASE_IMAGE} AS toolchain

ARG TORCH_VERSION="2.11.0"
# Building torch-spyre from coderfornow's `symbolic-stride-guard` branch:
# abhishekkunuru6-cmyk `diff` (storage_offset fix, PR #2426) + the scratchpad
# guard in _per_core_view_on_buf that stops the eager-serving InductorError
# "Cannot convert symbols to int" on transposed-view d2d copies (triggered by
# spyre-inference PR #206 list-based paged attention). TORCH_SPYRE_REF is
# fetched explicitly in the clone step below. Point REPO/REF back at upstream
# torch-spyre `main` (or a PR head ref) once this work lands.
ARG TORCH_SPYRE_REPO="git@github.com:coderfornow/torch-spyre.git"
ARG TORCH_SPYRE_REF="refs/heads/symbolic-stride-guard"
# flex SOURCE is cloned (not built) only so torch-spyre's _C.so can resolve flex
# source headers — chiefly the `common` submodule (common/self_doc_enum.hpp),
# which the installed /opt/ibm/spyre flex headers reference but don't ship.
# MUST match the base image's ibm-flex RPM commit (`rpm -q ibm-flex`). Bumped to
# flex main (eae2784) because PR #2426's _C.so calls the 4-arg
# RuntimeOperationCompute(..., tensor_byte_offsets) ctor added by flex #1099
# (merged daf1d82) and used by the VF runtime fix in flex #1103 (merged be768fc).
# The base image MUST carry a flex RPM at/after be768fc for this to link+run.
ARG FLEX_REF="eae27840c5803e20aa3537972958aaf7ac024849"
ARG PYTHON_VERSION="3.12"
ARG MAX_JOBS="16"

USER root
# Non-login shell: the base's /etc/profile.d/ AIU setup is for runtime; at build
# time we set all required env via ENV directives below.
SHELL ["/usr/bin/bash", "-c"]

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHON_VERSION=${PYTHON_VERSION}

##############################################
# Step 1 — build toolchain deps. This image is the base for Dockerfile.app.s390x,
# whose builder stages build numactl/opencv/vllm/hf-xet from source, so we
# provide a full build toolchain (matching the original Dockerfile.base.s390x
# package set), not just what the torch-spyre _C.so compile needs. e.g. numactl's
# autogen.sh needs autoreconf (autoconf/automake/libtool). Idempotent — the
# runtime-dev base already has gcc/gcc-c++/python3.12-devel.
##############################################
RUN dnf install -y \
        gcc gcc-c++ \
        libsndfile \
        libtiff-devel libpng-devel libwebp-devel \
        freetype-devel harfbuzz-devel \
        ninja-build \
        autoconf automake libtool \
        golang \
        dnf-plugins-core \
        libxml2-devel libxslt libxslt-devel \
        gcc-gfortran \
        clang clang-devel \
        openssl openssl-devel pkgconf-pkg-config \
        numactl-libs \
        ccache jq perl-core \
        cmake make git patch \
        python3.12-devel && \
    dnf clean all
# Notes on dropped packages (not available in UBI 10 / el10 for s390x, covered
# elsewhere): libatomic-devel (glibc provides libatomic; gcc-c++ has builtins),
# libomp/libomp-devel (GCC's libgomp covers the OpenMP runtime needs).

##############################################
# Step 2 — workspace layout + env. SAME contract as Dockerfile.base.s390x.
# DTI_PROJECT_ROOT=/home/senuser (senuser's home; the app image runs as 1234:0).
# uv is already on PATH in the base — no install step needed.
##############################################
ENV DTI_PROJECT_ROOT=/home/senuser
ENV SEN_PROJECT_SRC=${DTI_PROJECT_ROOT} \
    SEN_PROJECT_BUILD=${DTI_PROJECT_ROOT}/build \
    SENTIENT_BASE_INSTALL_DIR=${DTI_PROJECT_ROOT}/sentient
ENV DEEPTOOLS_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/deeptools \
    DEEPTOOLS_PATH=${SENTIENT_BASE_INSTALL_DIR}/deeptools/share \
    RUNTIME_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/runtime \
    RUNTIME_FULL_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/runtime \
    SENDNN_DIR=${SENTIENT_BASE_INSTALL_DIR}/runtime \
    SENDNN_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/runtime \
    LIBAIUPTI_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/libaiupti \
    SPYRE_COMMS_INSTALL_DIR=${SENTIENT_BASE_INSTALL_DIR}/spyre_comms \
    SENLIB_INSTALL_DIR=/opt/ibm/spyre/senlib

# flex's CMakeLists creates the SenLib::senlib target from ${SENLIB_PATH}/include;
# point at the base's senlib (we do not build senlib).

ENV PYTHONPATH=${SENTIENT_BASE_INSTALL_DIR}/runtime/lib \
    PATH=${DTI_PROJECT_ROOT}/.venv/bin:${SENTIENT_BASE_INSTALL_DIR}/runtime/bin:${SENTIENT_BASE_INSTALL_DIR}/deeptools/bin:/usr/local/bin:/usr/bin:/bin \
    LD_LIBRARY_PATH=${SENTIENT_BASE_INSTALL_DIR}/spyre_comms/lib:${SENTIENT_BASE_INSTALL_DIR}/libaiupti/lib:${SENTIENT_BASE_INSTALL_DIR}/runtime/lib:${SENTIENT_BASE_INSTALL_DIR}/deeptools/lib:/opt/ibm/spyre/senlib/lib:/usr/local/lib:/usr/lib64 \
    MAX_JOBS=${MAX_JOBS}

# Route C/C++ compiles through ccache so the torch-spyre _C.so rebuild benefits
# from the /root/.ccache cache mount on re-runs.
ENV CMAKE_C_COMPILER_LAUNCHER=ccache \
    CMAKE_CXX_COMPILER_LAUNCHER=ccache \
    CCACHE_DIR=/root/.ccache \
    CCACHE_MAXSIZE=30G

# venv targeting for uv (the venv is created below with --system-site-packages).
ENV VIRTUAL_ENV=${DTI_PROJECT_ROOT}/.venv \
    UV_PROJECT_ENVIRONMENT=${DTI_PROJECT_ROOT}/.venv \
    UV_PYTHON_PREFERENCE=only-system \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

# Rust/grpc/openssl crate build envs (consumed by the app image's rust/hf-xet/
# vllm stages, which inherit this image's ENV).
ENV LIBCLANG_PATH=/usr/lib64 \
    OPENSSL_DIR=/usr \
    OPENSSL_LIB_DIR=/usr/lib64 \
    OPENSSL_INCLUDE_DIR=/usr/include \
    OPENSSL_NO_VENDOR=1 \
    GRPC_PYTHON_BUILD_SYSTEM_OPENSSL=1 \
    GRPC_PYTHON_DISABLE_LIBC_COMPILER_CHECK=1

RUN mkdir -p ${DTI_PROJECT_ROOT}
WORKDIR ${DTI_PROJECT_ROOT}

##############################################
# Step 2b — git safe.directory + the SYMLINK FARM. The repos we clone under
# /home/senuser are senuser-owned and we run git as root. The symlink farm maps
# the overlay tree dev-env.sh / the app image expect
# (${SENTIENT_BASE_INSTALL_DIR}=/home/senuser/sentient) onto the prebuilt native
# stack at /opt/ibm/spyre, so the torch-spyre build finds flex/deeptools/sendnn
# headers+libs and PYTHONPATH resolves the native sendnn. Note the dash->under-
# score rename (spyre-comms -> spyre_comms); libaiupti.so is not shipped in this
# base (not a torch-spyre build dep) so sentient/libaiupti just points at runtime.
##############################################
RUN git config --global --add safe.directory '*' && \
    mkdir -p ${SENTIENT_BASE_INSTALL_DIR} && \
    ln -sfn /opt/ibm/spyre/runtime     ${SENTIENT_BASE_INSTALL_DIR}/runtime && \
    ln -sfn /opt/ibm/spyre/deeptools   ${SENTIENT_BASE_INSTALL_DIR}/deeptools && \
    ln -sfn /opt/ibm/spyre/spyre-comms ${SENTIENT_BASE_INSTALL_DIR}/spyre_comms && \
    ln -sfn /opt/ibm/spyre/runtime     ${SENTIENT_BASE_INSTALL_DIR}/libaiupti && \
    ls -l ${SENTIENT_BASE_INSTALL_DIR}

##############################################
# Step 3 — create the uv venv with --system-site-packages so it inherits the
# base's system torch_sendnn / torchvision / PIL, then install torch 2.11.0+cpu
# into the venv (so torch-spyre's uv sync resolves torch against the venv). torch
# in the base is already 2.11.0+cpu; this install is a harmless shadow.
##############################################
RUN uv venv --system-site-packages --python /usr/bin/python3.12 ${DTI_PROJECT_ROOT}/.venv

RUN uv pip install --no-cache \
        --index-url https://download.pytorch.org/whl/cpu \
        "torch==${TORCH_VERSION}"

##############################################
# Step 4 — bootstrap the uv-managed build tools (into the venv) needed to build
# torch-spyre's _C.so.
##############################################
RUN uv pip install --no-cache \
        "nanobind==2.9.2" ninja "pybind11==3.0.1" build "cmake~=3.26" regex wheel

##############################################
# Step 5 — pin torch-spyre-docs to our checked-out version (the build-script
# versions we validated).
##############################################
RUN rm -rf ${DTI_PROJECT_ROOT}/torch-spyre-docs
COPY ./torch-spyre-docs ${DTI_PROJECT_ROOT}/torch-spyre-docs

##############################################
# Step 6 — SSH host keys + clone torch-spyre (built) and flex source (headers
# only, NOT built). We do NOT run checkout-required-src.sh: the native stack
# (deeptools, flex binary, spyre-comms, libaiupti, torch_sendnn) is prebuilt in
# this base, and the script would also full-clone the huge llvm-project (no
# prebuilt llvm-project here to skip).
#
# flex source is required because torch-spyre's _C.so build adds
# -I${DTI_PROJECT_ROOT}/flex and includes flex's `common` submodule headers
# (e.g. common/self_doc_enum.hpp, pulled in transitively by senlib's pic.hpp).
# The installed /opt/ibm/spyre flex headers reference but don't ship those, so
# we clone flex WITH submodules at FLEX_REF (matching the base's ibm-flex RPM)
# purely for headers — flex itself is not rebuilt. The `common` submodule lives
# on github.ibm.com (spyre_common_headers), reachable with the same SSH key.
##############################################
RUN mkdir -p /root/.ssh && \
    ssh-keyscan -t rsa,ed25519 github.com github.ibm.com >> /root/.ssh/known_hosts 2>/dev/null

# Bump TORCH_SPYRE_CACHEBUST (e.g. --build-arg TORCH_SPYRE_CACHEBUST=$(date +%s))
# to force a fresh clone+build of torch-spyre WITHOUT re-running the expensive
# dnf/pip layers above. Needed whenever the branch tip moves but the ref name
# does not (podman would otherwise reuse the cached clone of the old commit).
ARG TORCH_SPYRE_CACHEBUST=0
RUN --mount=type=ssh \
    echo "torch-spyre cachebust: ${TORCH_SPYRE_CACHEBUST}" && \
    cd ${DTI_PROJECT_ROOT} && \
    git clone ${TORCH_SPYRE_REPO} torch-spyre && \
    cd torch-spyre && \
    git fetch --tags --prune origin "${TORCH_SPYRE_REF}:torch-spyre-build" && \
    git checkout torch-spyre-build && \
    git log --oneline -1

RUN --mount=type=ssh \
    cd ${DTI_PROJECT_ROOT} && \
    git clone --recurse-submodules git@github.ibm.com:ai-chip-toolchain/flex.git flex && \
    cd flex && \
    git fetch --all --tags --prune && \
    git checkout ${FLEX_REF} && \
    git submodule update --init --recursive

##############################################
# Step 7 — build ONLY torch-spyre against the prebuilt VF-capable flex/deeptools
# (via the symlink farm). dev-env.sh activates the venv and sets the env;
# build-torch-spyre.sh runs `uv sync` to compile _C.so + install torch-spyre into
# the venv. torch_sendnn is inherited from the base (manual dep, not resolved).
##############################################
RUN --mount=type=cache,target=/root/.ccache \
    set -e && \
    cd ${DTI_PROJECT_ROOT} && \
    . ./torch-spyre-docs/scripts/dev-env.sh && \
    ./torch-spyre-docs/scripts/build-torch-spyre.sh && \
    { ccache --show-stats || true; }

##############################################
# Step 8 — smoke test + guards. dev-env.sh sets PYTHONPATH=…/runtime/lib so the
# native sendnn module (and torch_sendnn) import, and LD_LIBRARY_PATH points at
# the prebuilt flex/deeptools.
##############################################
RUN . ${DTI_PROJECT_ROOT}/torch-spyre-docs/scripts/dev-env.sh && \
    python3 -c "import torch, torch_spyre, torch_sendnn; \
                print('toolchain ok:', torch.__version__, 'torch_spyre@', torch_spyre.__file__)"

# flex symbol guard — ${RUNTIME_INSTALL_DIR}/lib resolves via the symlink farm to
# /opt/ibm/spyre/runtime/lib (the prebuilt const-ABI flex w/ VF compute).
RUN nm -D ${RUNTIME_INSTALL_DIR}/lib/libflex.so | \
        grep -E 'RuntimeOperationCompute|setPipelineBarrier' >/dev/null || \
    { echo "ERROR: ${RUNTIME_INSTALL_DIR}/lib/libflex.so missing required symbols"; exit 1; }

# Single const-ABI libflex guard. There is only one libflex (the base's VF flex
# at /opt/ibm/spyre/runtime/lib, reached via the overlay symlink), so this is a
# fast no-op that also asserts the invariant the app image relies on.
COPY ./spyre-inference/container-scripts/reconcile-flex-runtime.sh /usr/local/bin/reconcile-flex-runtime.sh
RUN chmod +x /usr/local/bin/reconcile-flex-runtime.sh && \
    SPYRE_OVERLAY_DIR=${SENTIENT_BASE_INSTALL_DIR} /usr/local/bin/reconcile-flex-runtime.sh

##############################################
# Step 9 — slim. Drop the cmake build tree; keep the torch-spyre source so the
# app stage can find headers if needed. Ownership/cleanup is intentionally NOT
# done here — same as Dockerfile.base.s390x: Dockerfile.app.s390x is the
# authoritative normalizer (creates senuser, chown -R 1234:0 /home/senuser,
# /tmp/etc cleanup — Dockerfile.app.s390x:385-405).
##############################################
RUN rm -rf ${SEN_PROJECT_BUILD}

# Final WORKDIR — downstream Dockerfile inherits.
WORKDIR ${DTI_PROJECT_ROOT}